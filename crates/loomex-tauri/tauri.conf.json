{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Loomex",
  "version": "0.1.15",
  "identifier": "app.loomex.runner",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Loomex Runner",
        "width": 920,
        "height": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "DeveloperTool",
    "icon": ["icons/icon.png"]
  }
}
